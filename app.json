{
  "expo": {
    "name": "Autismo",
    "slug": "autism-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "autismapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.namuun.autismapp",
      "buildNumber": "1",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LittleLearner does not use the microphone.",
        "NSSpeechRecognitionUsageDescription": "LittleLearner does not use speech recognition.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Autismo does not track users."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.namuun.autismapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#7C5CFC",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#7C5CFC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dfc68828-cf75-498e-a82d-d7ff64464777"
      }
    }
  }
}
